      "Start": 9001,
      "End": 9099
    },
    "DefaultImageTag": "fishaudio/fish-speech:server-cuda-v2.0.0-beta",
    "DockerNetworkName": "oao-network",
    "HealthCheckIntervalSeconds": 30,
    "Domain": "",
    "AdminUser": "",
    "AdminPassword": "",
    "DatabaseKey": ""
  },
  "LettuceEncrypt": {
    "AcceptTermsOfService": true,
    "DomainNames": [],
    "EmailAddress": ""
  }
}

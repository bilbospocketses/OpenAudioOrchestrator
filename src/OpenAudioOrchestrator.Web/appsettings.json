{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=C:\\MyOpenAudioProj\\AudioOrchestrator.db"
  },
  "OpenAudioOrchestrator": {
    "DockerEndpoint": "npipe://./pipe/docker_engine",
    "DataRoot": "C:\\MyOpenAudioProj",

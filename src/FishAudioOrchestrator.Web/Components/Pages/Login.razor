@page "/login"
@layout EmptyLayout

<PageTitle>Login — Fish Audio Orchestrator</PageTitle>

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="card border-secondary" style="width: 400px;">
        <div class="card-body">
            <h3 class="card-title text-center mb-4">Fish Audio Orchestrator</h3>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger">@_error</div>
            }

            <form method="post" action="/api/auth/login">
                <AntiforgeryToken />
                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <input name="username" class="form-control border-secondary" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input name="password" type="password" class="form-control border-secondary" required />
                </div>
                <button type="submit" class="btn btn-primary w-100">Sign In</button>
            </form>
        </div>
    </div>
</div>

@code {
    private string? _error;

    [SupplyParameterFromQuery(Name = "error")]
    private string? ErrorCode { get; set; }

    protected override void OnInitialized()
    {
        _error = ErrorCode switch
        {
            "invalid" => "Invalid username or password.",
            "locked" => "Account locked. Try again later.",
            _ => null
        };
    }
}

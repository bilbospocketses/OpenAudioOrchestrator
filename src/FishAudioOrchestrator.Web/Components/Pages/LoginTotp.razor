@page "/login/totp"
@using Microsoft.AspNetCore.Identity
@using Microsoft.Extensions.Caching.Memory
@using System.Security.Cryptography
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager
@inject NavigationManager Nav
@inject IMemoryCache Cache
@inject IJSRuntime JS
@layout EmptyLayout

<PageTitle>Verify TOTP — Fish Audio Orchestrator</PageTitle>

<div class="d-flex justify-content-center align-items-center vh-100 bg-dark">
    <div class="card bg-dark text-light border-secondary" style="width: 400px;">
        <div class="card-body">
            <h3 class="card-title text-center mb-4">Two-Factor Authentication</h3>
            <p class="text-muted text-center">Enter the 6-digit code from your authenticator app.</p>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger">@_error</div>
            }

            <EditForm Model="_model" OnValidSubmit="HandleVerify" FormName="totp">
                <div class="mb-3">
                    <label class="form-label">Code</label>
                    <InputText @bind-Value="_model.Code" class="form-control bg-dark text-light border-secondary text-center"
                               maxlength="6" autocomplete="one-time-code" />
                </div>
                <button type="submit" class="btn btn-primary w-100" disabled="@(_loading || _expired)">
                    @(_loading ? "Verifying..." : "Verify")
                </button>
            </EditForm>

            @if (_secondsRemaining > 0)
            {
                <div class="text-center mt-3 mb-2">
                    <small class="@(_secondsRemaining <= 30 ? "text-warning" : "text-muted")">
                        Time remaining: @(_secondsRemaining)s
                    </small>
                </div>
            }
            else if (_expired)
            {
                <div class="alert alert-warning mt-3 mb-2 text-center">
                    Session expired. <a href="/login">Return to login</a>.
                </div>
            }

            <div class="text-center mt-2">
                <a href="/login" class="text-muted">Back to login</a>
            </div>
        </div>
    </div>
</div>

<form id="signin-form" method="post" action="/api/auth/signin" style="display:none;">
    <input type="hidden" name="token" id="signin-token" />
    <input type="hidden" name="returnUrl" id="signin-return-url" />
</form>

@implements IDisposable

@code {
    private TotpModel _model = new();
    private string? _error;
    private bool _loading;
    private AppUser? _user;
    private string? _pendingToken;
    private int _secondsRemaining = 120;
    private bool _expired;
    private Timer? _countdownTimer;

    [SupplyParameterFromQuery(Name = "tid")]
    private string? TokenId { get; set; }

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private sealed class TotpModel
    {
        public string Code { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(TokenId))
        {
            Nav.NavigateTo("/login", forceLoad: true);
            return;
        }

        _pendingToken = TokenId;

        // Resolve user from opaque token (don't remove yet — TOTP verification hasn't happened)
        if (!Cache.TryGetValue($"totp-pending:{_pendingToken}", out string? userId) || userId is null)
        {
            Nav.NavigateTo("/login", forceLoad: true);
            return;
        }

        _user = await UserManager.FindByIdAsync(userId);
        if (_user is null)
        {
            Nav.NavigateTo("/login", forceLoad: true);
            return;
        }

        _countdownTimer = new Timer(_ => InvokeAsync(() =>
        {
            _secondsRemaining--;
            if (_secondsRemaining <= 0)
            {
                _expired = true;
                _countdownTimer?.Dispose();
                _countdownTimer = null;
            }
            StateHasChanged();
        }), null, 1000, 1000);
    }

    private async Task HandleVerify()
    {
        _error = null;
        _loading = true;

        if (_user is null || _pendingToken is null || _expired)
        {
            Nav.NavigateTo("/login", forceLoad: true);
            return;
        }

        // Rate-limit TOTP attempts — invalidate after 5 failures
        var attemptKey = $"totp-attempts:{_pendingToken}";
        var attempts = Cache.GetOrCreate(attemptKey, e =>
        {
            e.AbsoluteExpirationRelativeToNow = TimeSpan.FromMinutes(5);
            return 0;
        });

        if (attempts >= 5)
        {
            Cache.Remove($"totp-pending:{_pendingToken}");
            Cache.Remove(attemptKey);
            Nav.NavigateTo("/login?error=locked", forceLoad: true);
            return;
        }

        var isValid = await UserManager.VerifyTwoFactorTokenAsync(_user,
            UserManager.Options.Tokens.AuthenticatorTokenProvider, _model.Code.Trim());

        if (!isValid)
        {
            Cache.Set(attemptKey, attempts + 1, TimeSpan.FromMinutes(5));
            _error = $"Invalid code. Please try again. ({4 - attempts} attempts remaining)";
            _loading = false;
            return;
        }

        // Consume the pending token and attempt counter
        Cache.Remove($"totp-pending:{_pendingToken}");
        Cache.Remove(attemptKey);

        // Generate a one-time token proving TOTP was verified
        var token = Convert.ToBase64String(RandomNumberGenerator.GetBytes(32));
        Cache.Set($"totp-verified:{token}", _user.Id, TimeSpan.FromSeconds(60));

        await JS.InvokeVoidAsync("submitSigninForm", token, ReturnUrl ?? "");
    }

    public void Dispose()
    {
        _countdownTimer?.Dispose();
    }
}

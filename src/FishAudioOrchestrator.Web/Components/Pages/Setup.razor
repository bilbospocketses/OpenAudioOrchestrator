@page "/setup"
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using System.Text.RegularExpressions
@inject UserManager<AppUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject ITotpService TotpService
@inject IConfiguration Config
@inject IWebHostEnvironment Env
@inject NavigationManager Nav
@inject SetupDownloadService DownloadSvc
@inject SetupSettingsService SettingsSvc
@layout EmptyLayout

<PageTitle>Setup — Fish Audio Orchestrator</PageTitle>

<div class="d-flex justify-content-center align-items-center min-vh-100 py-4">
    <div class="card border-secondary" style="width: 600px;">
        <div class="card-body">
            <h3 class="card-title text-center mb-2">Fish Audio Orchestrator Setup</h3>
            <p class="text-muted text-center mb-4">Step @_step of 7</p>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger">@_error</div>
            }
            @if (_step == 1)
            {
                @* --- Step 1: Data Directories --- *@
                <h5>Data Storage</h5>
                <p class="text-muted">Fish Audio Orchestrator stores its database, model checkpoints, reference voice samples, and generated audio files. Choose where to store each. Directories will be created if they don't exist.</p>

                <div class="mb-3">
                    <label class="form-label">Database File</label>
                    <input class="form-control border-secondary" @bind="_databasePath" />
                    <small class="text-muted">SQLite database file path (e.g. fishorch.db)</small>
                </div>
                <div class="mb-3">
                    <label class="form-label">Checkpoints Directory</label>
                    <input class="form-control border-secondary" @bind="_checkpointsDir" />
                    <small class="text-muted">Model checkpoint files (e.g. s2-pro)</small>
                </div>
                <div class="mb-3">
                    <label class="form-label">References Directory</label>
                    <input class="form-control border-secondary" @bind="_referencesDir" />
                    <small class="text-muted">Voice reference audio samples for cloning</small>
                </div>
                <div class="mb-3">
                    <label class="form-label">Output Directory</label>
                    <input class="form-control border-secondary" @bind="_outputDir" />
                    <small class="text-muted">Generated speech audio files</small>
                </div>
                <button class="btn btn-primary w-100" @onclick="ValidateStep1">Next</button>
            }
            else if (_step == 2)
            {
                @* --- Step 2: Model Download --- *@
                <h5>Download Fish Speech Model</h5>
                <p class="text-muted">Fish Audio Orchestrator requires the Fish Audio s2-pro model. This is a large download (~11 GB) from HuggingFace. Git with Git LFS support must be installed.</p>

                @if (_modelAlreadyPresent)
                {
                    <div class="alert alert-success">Model already downloaded.</div>
                    <button class="btn btn-primary w-100" @onclick="GoToStep3">Next</button>
                }
                else if (!string.IsNullOrEmpty(_preCheckError))
                {
                    <div class="alert alert-warning" style="white-space: pre-wrap;">@_preCheckError</div>
                    <button class="btn btn-outline-light w-100 mb-2" @onclick="RunModelPreChecks">Retry</button>
                    <button class="btn btn-outline-secondary w-100" @onclick="SkipModelDownload">Skip — I'll download it manually later</button>
                }
                else if (DownloadSvc.IsModelDownloading)
                {
                    <div class="mb-3">
                        <div class="bg-dark border border-secondary rounded p-2" style="height: 200px; overflow-y: auto; font-family: monospace; font-size: 0.8em;">
                            @foreach (var line in _downloadOutput)
                            {
                                <div>@line</div>
                            }
                        </div>
                    </div>
                    <button class="btn btn-primary w-100" @onclick="GoToStep3">Next (download continues in background)</button>
                }
                else if (DownloadSvc.ModelDownloadCompleted)
                {
                    <div class="alert alert-success">Model downloaded successfully.</div>
                    <button class="btn btn-primary w-100" @onclick="GoToStep3">Next</button>
                }
                else if (!string.IsNullOrEmpty(DownloadSvc.ModelDownloadError))
                {
                    <div class="alert alert-danger">@DownloadSvc.ModelDownloadError</div>
                    <div class="bg-dark border border-secondary rounded p-2 mb-3" style="height: 150px; overflow-y: auto; font-family: monospace; font-size: 0.8em;">
                        @foreach (var line in _downloadOutput)
                        {
                            <div>@line</div>
                        }
                    </div>
                    <button class="btn btn-outline-light w-100 mb-2" @onclick="StartModelDownload">Retry Download</button>
                    <button class="btn btn-outline-secondary w-100" @onclick="SkipModelDownload">Skip</button>
                }
                else
                {
                    <button class="btn btn-success w-100 mb-2" @onclick="StartModelDownload">Download Model (~11 GB)</button>
                    <button class="btn btn-outline-secondary w-100" @onclick="SkipModelDownload">Skip — I'll download it manually later</button>
                }

                <div class="text-center mt-4">
                    <a href="https://huggingface.co/fishaudio/s2-pro/blob/main/LICENSE.md" target="_blank" class="text-muted"><strong>Built with Fish Audio</strong></a>
                </div>
                <p class="text-muted small text-center mt-2">The Fish Audio S2 Pro models are for non-commercial research use only. Commercial use requires a separate license from Fish Audio.</p>
            }
            else if (_step == 3)
            {
                @* --- Step 3: Docker Image --- *@
                <h5>Download Docker Image</h5>
                <p class="text-muted">Fish Audio Orchestrator runs the TTS model inside a Docker container. The required image is approximately 12 GB.</p>

                @if (_dockerImagePresent)
                {
                    <div class="alert alert-success">Docker image already available.</div>
                    <button class="btn btn-primary w-100" @onclick="() => _step = 4">Next</button>
                }
                else if (!string.IsNullOrEmpty(_preCheckError))
                {
                    <div class="alert alert-warning" style="white-space: pre-wrap;">@_preCheckError</div>
                    <button class="btn btn-outline-light w-100" @onclick="RunDockerPreChecks">Retry</button>
                }
                else if (DownloadSvc.IsDockerPulling)
                {
                    <div class="mb-3">
                        <div class="bg-dark border border-secondary rounded p-2" style="height: 200px; overflow-y: auto; font-family: monospace; font-size: 0.8em;">
                            @foreach (var line in _pullOutput)
                            {
                                <div>@line</div>
                            }
                        </div>
                    </div>
                    <button class="btn btn-primary w-100" @onclick="() => _step = 4">Next (download continues in background)</button>
                }
                else if (DownloadSvc.DockerPullCompleted)
                {
                    <div class="alert alert-success">Docker image downloaded successfully.</div>
                    <button class="btn btn-primary w-100" @onclick="() => _step = 4">Next</button>
                }
                else if (!string.IsNullOrEmpty(DownloadSvc.DockerPullError))
                {
                    <div class="alert alert-danger">@DownloadSvc.DockerPullError</div>
                    <div class="bg-dark border border-secondary rounded p-2 mb-3" style="height: 150px; overflow-y: auto; font-family: monospace; font-size: 0.8em;">
                        @foreach (var line in _pullOutput)
                        {
                            <div>@line</div>
                        }
                    </div>
                    <button class="btn btn-outline-light w-100" @onclick="StartDockerPull">Retry Download</button>
                }
                else
                {
                    <button class="btn btn-success w-100" @onclick="StartDockerPull">Download Docker Image (~12 GB)</button>
                }

                <div class="text-center mt-4">
                    <a href="https://huggingface.co/fishaudio/s2-pro/blob/main/LICENSE.md" target="_blank" class="text-muted"><strong>Built with Fish Audio</strong></a>
                </div>
                <p class="text-muted small text-center mt-2">The Fish Audio S2 Pro models are for non-commercial research use only. Commercial use requires a separate license from Fish Audio.</p>
            }
            else if (_step == 4)
            {
                @* --- Step 4: Server Configuration --- *@
                <h5>Server Configuration</h5>
                <p class="text-muted">Configure how Docker containers are assigned ports, and optionally set up a domain for automatic HTTPS.</p>

                <h6 class="mt-3">Container Port Range</h6>
                <p class="text-muted small">When deploying models, each container is assigned a port from this range. Most users need only 1-2 ports unless running multiple models on a high-end GPU.</p>
                <div class="row mb-3">
                    <div class="col">
                        <label class="form-label">Start Port</label>
                        <input type="number" class="form-control border-secondary" @bind="_portStart" />
                    </div>
                    <div class="col">
                        <label class="form-label">End Port</label>
                        <input type="number" class="form-control border-secondary" @bind="_portEnd" />
                    </div>
                </div>

                <h6 class="mt-4">Database Encryption</h6>
                <p class="text-muted small">Encrypt the SQLite database at rest using SQLCipher. Strongly recommended. The key is stored in appsettings.json and is required to open the database on future startups.</p>
                <div class="mb-3">
                    <label class="form-label">Database Encryption Key</label>
                    <div class="input-group">
                        <input class="form-control border-secondary" @bind="_databaseKey"
                               placeholder="Leave blank to skip encryption" />
                        <button type="button" class="btn btn-outline-light" @onclick="GenerateDatabaseKey">Generate</button>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_databaseKey))
                    {
                        <div class="alert alert-danger small mt-2">
                            <strong>WARNING:</strong> This key is the only way to access your encrypted database.
                            If you lose this key, your database — including all user accounts, generation history,
                            and voice library data — <strong>cannot be recovered</strong>.
                            Copy this key now and store it in a secure location (e.g. password manager, secure note, or printed backup).
                        </div>
                        <div class="form-check mt-2">
                            <input class="form-check-input" type="checkbox" id="keyBackupConfirm" @bind="_keyBackupConfirmed" />
                            <label class="form-check-label" for="keyBackupConfirm">
                                I have saved this key in a secure location and understand it cannot be recovered if lost.
                            </label>
                        </div>
                    }
                </div>

                <h6 class="mt-4">Domain & HTTPS (Optional)</h6>
                <p class="text-muted small">By default, the app runs on port 5206 over HTTP. If you have a domain name pointing to this server and want automatic HTTPS via Let's Encrypt, enter it below. Otherwise, leave blank.</p>
                <div class="mb-3">
                    <label class="form-label">Domain</label>
                    <input class="form-control border-secondary" @bind="_domain" placeholder="e.g. fish.example.com" />
                </div>

                @if (!string.IsNullOrWhiteSpace(_domain))
                {
                    <div class="mb-3">
                        <label class="form-label">Email Address (required for Let's Encrypt)</label>
                        <input class="form-control border-secondary" @bind="_email" placeholder="admin@example.com" />
                    </div>
                    <div class="alert alert-info small">
                        <strong>Important:</strong> After setup, restart the app and navigate to <strong>https://@_domain</strong>.
                        The domain must have a DNS A record pointing to this server's public IP address.
                        Ports 80 and 443 must be accessible from the internet for Let's Encrypt to validate domain ownership and provision the certificate.
                        If you are unfamiliar with DNS configuration and certificate provisioning, consult an AI assistant or your DNS provider's documentation before proceeding.
                    </div>
                }
                else
                {
                    <p class="text-muted small">After setup, restart the app and navigate to <strong>http://localhost:5206</strong>.</p>
                }

                <button class="btn btn-primary w-100" @onclick="ValidateStep4">Next</button>
            }
            else if (_step == 5)
            {
                @* --- Step 5: Create Admin Account --- *@
                <h5>Create Admin Account</h5>
                <p class="text-muted">Create the first administrator account. This account has full access to all features.</p>

                <EditForm Model="_adminModel" OnValidSubmit="CreateAdmin" FormName="setup-admin">
                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <InputText @bind-Value="_adminModel.Username" class="form-control border-secondary" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Display Name</label>
                        <InputText @bind-Value="_adminModel.DisplayName" class="form-control border-secondary" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <InputText @bind-Value="_adminModel.Password" type="password" class="form-control border-secondary" />
                        <div class="form-text text-muted">8+ characters, upper, lower, digit, special character.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Confirm Password</label>
                        <InputText @bind-Value="_adminModel.ConfirmPassword" type="password" class="form-control border-secondary" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Next</button>
                </EditForm>
            }
            else if (_step == 6)
            {
                @* --- Step 6: TOTP Setup --- *@
                <h5>TOTP Setup</h5>
                <p class="text-muted">Scan this QR code with your authenticator app (Google Authenticator, Authy, etc.).</p>

                @if (!string.IsNullOrEmpty(_qrDataUri))
                {
                    <div class="text-center mb-3">
                        <img src="@_qrDataUri" alt="TOTP QR Code" style="width: 200px; height: 200px;" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Manual Key</label>
                        <input type="text" readonly class="form-control border-secondary text-center" value="@_manualKey" />
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label">Enter 6-digit code to verify</label>
                    <InputText @bind-Value="_totpCode" class="form-control border-secondary text-center" maxlength="6" />
                </div>
                <button class="btn btn-primary w-100" @onclick="VerifyTotpAndComplete" disabled="@_loading">
                    @(_loading ? "Completing setup..." : "Complete Setup")
                </button>
            }
            else if (_step == 7)
            {
                @* --- Step 7: Setup Complete --- *@
                <h5>Setup Complete</h5>

                @if (DownloadSvc.HasActiveDownloads)
                {
                    <div class="alert alert-warning">
                        Downloads are still in progress. Please wait for them to complete before restarting the application.
                        Stopping the app now will cancel the downloads and they will need to start over.
                    </div>

                    @if (DownloadSvc.IsModelDownloading)
                    {
                        <h6>Model Download</h6>
                        <div class="bg-dark border border-secondary rounded p-2 mb-3" style="height: 150px; overflow-y: auto; font-family: monospace; font-size: 0.8em;">
                            @foreach (var line in DownloadSvc.GetModelDownloadOutput())
                            {
                                <div>@line</div>
                            }
                        </div>
                    }

                    @if (DownloadSvc.IsDockerPulling)
                    {
                        <h6>Docker Image Download</h6>
                        <div class="bg-dark border border-secondary rounded p-2 mb-3" style="height: 150px; overflow-y: auto; font-family: monospace; font-size: 0.8em;">
                            @foreach (var line in DownloadSvc.GetDockerPullOutput())
                            {
                                <div>@line</div>
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-success">
                        <p><strong>Database:</strong> @Path.GetFullPath(_databasePath)</p>
                        <p><strong>Data directories:</strong> Configured</p>
                        <p><strong>Model:</strong> @(_modelSkipped ? "Skipped (download manually before deploying)" : "Downloaded")</p>
                        <p><strong>Docker image:</strong> @(DownloadSvc.DockerPullCompleted || _dockerImagePresent ? "Available" : "Not downloaded")</p>
                        <p><strong>Port range:</strong> @_portStart - @_portEnd</p>
                        @if (!string.IsNullOrWhiteSpace(_domain))
                        {
                            <p><strong>Domain:</strong> @_domain</p>
                        }
                        <p><strong>Database encryption:</strong> @(string.IsNullOrWhiteSpace(_databaseKey) ? "Disabled" : "Enabled (SQLCipher)")</p>
                        <p><strong>Admin account:</strong> @_adminModel.Username</p>
                        <p><strong>TOTP:</strong> Enabled</p>
                    </div>

                    <div class="card border-secondary mb-3">
                        <div class="card-body">
                            <p>Stop the application (<code>Ctrl+C</code> in the terminal) and restart with:</p>
                            <pre class="text-info p-2 rounded">dotnet run --project src/FishAudioOrchestrator.Web</pre>
                            @if (!string.IsNullOrWhiteSpace(_domain))
                            {
                                <p>Then navigate to <strong>https://@_domain</strong></p>
                            }
                            else
                            {
                                <p>Then navigate to <strong>http://localhost:5206</strong></p>
                            }
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@implements IAsyncDisposable

@code {
    private int _step = 1;
    private string? _error;
    private string? _preCheckError;
    private bool _loading;

    // Step 1
    private string _databasePath = @"C:\MyOpenAudioProj\fishorch.db";
    private string _checkpointsDir = @"C:\MyOpenAudioProj\Checkpoints";
    private string _referencesDir = @"C:\MyOpenAudioProj\References";
    private string _outputDir = @"C:\MyOpenAudioProj\Output";

    // Step 2
    private bool _modelAlreadyPresent;
    private bool _modelSkipped;
    private List<string> _downloadOutput = new();
    private Timer? _downloadTimer;

    // Step 3
    private bool _dockerImagePresent;
    private List<string> _pullOutput = new();
    private Timer? _pullTimer;
    private string _imageTag = "fishaudio/fish-speech:server-cuda-v2.0.0-beta";

    // Step 4
    private int _portStart = 9001;
    private int _portEnd = 9099;
    private string _domain = "";
    private string _email = "";
    private string _databaseKey = "";
    private bool _keyBackupConfirmed;

    // Steps 5-6
    private AdminModel _adminModel = new();
    private string? _qrDataUri;
    private string? _manualKey;
    private string _totpCode = "";
    private AppUser? _createdUser;

    // Step 7
    private Timer? _completionTimer;

    // Disposal guard
    private readonly CancellationTokenSource _disposeCts = new();

    private sealed class AdminModel
    {
        public string Username { get; set; } = "";
        public string DisplayName { get; set; } = "";
        public string Password { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        if (await UserManager.Users.AnyAsync())
        {
            Nav.NavigateTo("/", forceLoad: true);
        }
    }

    // --- Step 1: Data Directories ---

    private void ValidateStep1()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_databasePath) ||
            string.IsNullOrWhiteSpace(_checkpointsDir) ||
            string.IsNullOrWhiteSpace(_referencesDir) ||
            string.IsNullOrWhiteSpace(_outputDir))
        {
            _error = "All fields are required.";
            return;
        }

        _databasePath = _databasePath.Trim();

        // Validate database path has a filename
        if (string.IsNullOrWhiteSpace(Path.GetFileName(_databasePath)))
        {
            _error = "Database path must include a filename (e.g. fishorch.db).";
            return;
        }

        // Ensure the database directory exists
        var dbDir = Path.GetDirectoryName(Path.GetFullPath(_databasePath));
        if (dbDir is not null)
        {
            try
            {
                if (!Directory.Exists(dbDir))
                    Directory.CreateDirectory(dbDir);
            }
            catch (Exception ex)
            {
                _error = $"Could not create database directory '{dbDir}': {ex.Message}";
                return;
            }
        }

        var dirs = new[] { _checkpointsDir.Trim(), _referencesDir.Trim(), _outputDir.Trim() };
        var normalized = dirs.Select(d => Path.GetFullPath(d).TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar).ToLowerInvariant()).ToArray();
        if (normalized.Distinct().Count() != 3)
        {
            _error = "Each directory must be unique.";
            return;
        }

        foreach (var dir in dirs)
        {
            try
            {
                if (!Directory.Exists(dir))
                    Directory.CreateDirectory(dir);
            }
            catch (Exception ex)
            {
                _error = $"Could not create directory '{dir}': {ex.Message}";
                return;
            }
        }

        _checkpointsDir = dirs[0];
        _referencesDir = dirs[1];
        _outputDir = dirs[2];

        _modelAlreadyPresent = DownloadSvc.IsModelPresent(_checkpointsDir);
        _ = RunModelPreChecks();

        _step = 2;
    }

    // --- Step 2: Model Download ---

    private async Task RunModelPreChecks()
    {
        _preCheckError = null;
        _modelAlreadyPresent = DownloadSvc.IsModelPresent(_checkpointsDir);
        if (_modelAlreadyPresent) { StateHasChanged(); return; }

        var (gitOk, gitError) = await DownloadSvc.CheckGitAsync();
        if (!gitOk) { _preCheckError = gitError; StateHasChanged(); return; }

        var (lfsOk, lfsError) = await DownloadSvc.CheckGitLfsAsync();
        if (!lfsOk) { _preCheckError = lfsError; }
        StateHasChanged();
    }

    private void StartModelDownload()
    {
        _error = null;
        DownloadSvc.StartModelDownload(_checkpointsDir, () => InvokeAsync(RefreshDownloadOutput));
        _downloadTimer = new Timer(_ => InvokeAsync(RefreshDownloadOutput), null, 1000, 2000);
    }

    private void RefreshDownloadOutput()
    {
        if (_disposeCts.IsCancellationRequested) return;
        _downloadOutput = DownloadSvc.GetModelDownloadOutput();
        if (!DownloadSvc.IsModelDownloading)
        {
            _downloadTimer?.Dispose();
            _downloadTimer = null;
            _modelAlreadyPresent = DownloadSvc.ModelDownloadCompleted;
        }
        StateHasChanged();
    }

    private void SkipModelDownload()
    {
        _modelSkipped = true;
        GoToStep3();
    }

    private void GoToStep3()
    {
        _preCheckError = null;
        _step = 3;
        _ = RunDockerPreChecks();
    }

    // --- Step 3: Docker Image ---

    private async Task RunDockerPreChecks()
    {
        _preCheckError = null;

        var (dockerOk, dockerError) = await DownloadSvc.CheckDockerAsync();
        if (!dockerOk) { _preCheckError = dockerError; StateHasChanged(); return; }

        _dockerImagePresent = await DownloadSvc.IsDockerImagePresentAsync(_imageTag);
        StateHasChanged();
    }

    private void StartDockerPull()
    {
        _error = null;
        DownloadSvc.StartDockerPull(_imageTag, () => InvokeAsync(RefreshPullOutput));
        _pullTimer = new Timer(_ => InvokeAsync(RefreshPullOutput), null, 1000, 2000);
    }

    private void RefreshPullOutput()
    {
        if (_disposeCts.IsCancellationRequested) return;
        _pullOutput = DownloadSvc.GetDockerPullOutput();
        if (!DownloadSvc.IsDockerPulling)
        {
            _pullTimer?.Dispose();
            _pullTimer = null;
            _dockerImagePresent = DownloadSvc.DockerPullCompleted;
        }
        StateHasChanged();
    }

    // --- Step 4: Configuration ---

    private void GenerateDatabaseKey()
    {
        _databaseKey = SetupSettingsService.GenerateDatabaseKey();
        _keyBackupConfirmed = false;
    }

    private void ValidateStep4()
    {
        _error = null;

        if (!string.IsNullOrWhiteSpace(_databaseKey) && !_keyBackupConfirmed)
        {
            _error = "You must confirm that you have saved the encryption key before continuing.";
            return;
        }

        if (!SetupValidation.IsValidPort(_portStart) || !SetupValidation.IsValidPort(_portEnd))
        {
            _error = "Ports must be between 1024 and 65535.";
            return;
        }
        if (_portStart >= _portEnd)
        {
            _error = "Start port must be less than end port.";
            return;
        }

        if (!string.IsNullOrWhiteSpace(_domain))
        {
            if (!SetupValidation.IsValidDomain(_domain.Trim()))
            {
                _error = "Invalid domain format. Example: fish.example.com";
                return;
            }
            if (string.IsNullOrWhiteSpace(_email) || !SetupValidation.IsValidEmail(_email.Trim()))
            {
                _error = "A valid email address is required for Let's Encrypt certificate provisioning.";
                return;
            }
        }

        _step = 5;
    }

    // --- Step 5: Create Admin ---

    private async Task CreateAdmin()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_adminModel.Username))
        { _error = "Username is required."; return; }
        if (string.IsNullOrWhiteSpace(_adminModel.DisplayName))
        { _error = "Display name is required."; return; }
        if (_adminModel.Password != _adminModel.ConfirmPassword)
        { _error = "Passwords do not match."; return; }

        var user = new AppUser
        {
            UserName = _adminModel.Username,
            DisplayName = _adminModel.DisplayName,
            MustChangePassword = false,
            MustSetupTotp = true,
            CreatedAt = DateTimeOffset.UtcNow
        };

        var result = await UserManager.CreateAsync(user, _adminModel.Password);
        if (!result.Succeeded)
        {
            _error = string.Join(" ", result.Errors.Select(e => e.Description));
            return;
        }

        await UserManager.AddToRoleAsync(user, "Admin");
        _createdUser = user;

        var (manualKey, qrDataUri) = await TotpService.GenerateSetupInfoAsync(user, "FishOrchestrator");
        _manualKey = manualKey;
        _qrDataUri = qrDataUri;
        _step = 6;
    }

    // --- Step 6: TOTP ---

    private async Task VerifyTotpAndComplete()
    {
        _error = null;
        _loading = true;

        if (_createdUser is null)
        {
            _error = "Setup error. Please refresh and start over.";
            _loading = false;
            return;
        }

        var isValid = await TotpService.VerifyCodeAsync(_createdUser, _totpCode.Trim());
        if (!isValid)
        {
            _error = "Invalid code. Please try again.";
            _loading = false;
            return;
        }

        await UserManager.SetTwoFactorEnabledAsync(_createdUser, true);
        _createdUser.MustSetupTotp = false;
        await UserManager.UpdateAsync(_createdUser);

        // Move the database file to the user-specified path if different from the current location
        var currentDbPath = GetCurrentDatabasePath();
        var targetDbPath = Path.GetFullPath(_databasePath);
        if (currentDbPath is not null && !string.Equals(currentDbPath, targetDbPath, StringComparison.OrdinalIgnoreCase))
        {
            try
            {
                // EF Core SQLite holds the connection; we need to copy instead of move
                var targetDir = Path.GetDirectoryName(targetDbPath);
                if (targetDir is not null && !Directory.Exists(targetDir))
                    Directory.CreateDirectory(targetDir);
                File.Copy(currentDbPath, targetDbPath, overwrite: true);

                // Also copy WAL/SHM if they exist
                var walSrc = currentDbPath + "-wal";
                var shmSrc = currentDbPath + "-shm";
                if (File.Exists(walSrc)) File.Copy(walSrc, targetDbPath + "-wal", overwrite: true);
                if (File.Exists(shmSrc)) File.Copy(shmSrc, targetDbPath + "-shm", overwrite: true);

                // Clean up the original files so we don't leave crud behind
                try { File.Delete(currentDbPath); } catch { }
                try { if (File.Exists(walSrc)) File.Delete(walSrc); } catch { }
                try { if (File.Exists(shmSrc)) File.Delete(shmSrc); } catch { }

                // If the original directory is now empty, remove it too
                var originalDir = Path.GetDirectoryName(currentDbPath);
                if (originalDir is not null && Directory.Exists(originalDir)
                    && !Directory.EnumerateFileSystemEntries(originalDir).Any())
                {
                    try { Directory.Delete(originalDir); } catch { }
                }
            }
            catch (Exception ex)
            {
                _error = $"Failed to copy database to '{targetDbPath}': {ex.Message}";
                _loading = false;
                return;
            }
        }

        // Save all settings to appsettings.json (after user creation so DB path points to the right file)
        try
        {
            await SettingsSvc.SaveSettingsAsync(
                _databasePath,
                _checkpointsDir, _referencesDir, _outputDir,
                _portStart, _portEnd,
                string.IsNullOrWhiteSpace(_domain) ? null : _domain.Trim(),
                string.IsNullOrWhiteSpace(_email) ? null : _email.Trim(),
                string.IsNullOrWhiteSpace(_databaseKey) ? null : _databaseKey.Trim());
        }
        catch (Exception ex)
        {
            _error = $"Failed to save settings: {ex.Message}";
            _loading = false;
            return;
        }

        // Encrypt the database if a key was provided in Step 4
        if (!string.IsNullOrWhiteSpace(_databaseKey))
        {
            try
            {
                await SettingsSvc.EncryptDatabaseAsync(targetDbPath, _databaseKey.Trim());
            }
            catch (Exception ex)
            {
                _error = $"Database encryption failed: {ex.Message}. The database is unencrypted. You can retry encryption manually after restarting.";
                _loading = false;
                return;
            }
        }

        _step = 7;
        _loading = false;

        if (DownloadSvc.HasActiveDownloads)
        {
            _completionTimer = new Timer(_ => InvokeAsync(() =>
            {
                if (_disposeCts.IsCancellationRequested) return;
                if (!DownloadSvc.HasActiveDownloads)
                {
                    _completionTimer?.Dispose();
                    _completionTimer = null;
                }
                StateHasChanged();
            }), null, 2000, 3000);
        }
    }

    private string? GetCurrentDatabasePath()
    {
        var connStr = Config.GetConnectionString("Default");
        if (connStr is null) return null;
        var prefix = "Data Source=";
        var idx = connStr.IndexOf(prefix, StringComparison.OrdinalIgnoreCase);
        if (idx < 0) return null;
        var pathStart = idx + prefix.Length;
        var semicolonIdx = connStr.IndexOf(';', pathStart);
        var path = semicolonIdx >= 0 ? connStr[pathStart..semicolonIdx] : connStr[pathStart..];
        return Path.GetFullPath(path);
    }

    public ValueTask DisposeAsync()
    {
        _disposeCts.Cancel();
        _disposeCts.Dispose();
        _downloadTimer?.Dispose();
        _pullTimer?.Dispose();
        _completionTimer?.Dispose();
        return ValueTask.CompletedTask;
    }
}

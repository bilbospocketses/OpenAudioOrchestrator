@page "/deploy"
@attribute [Authorize(Roles = "Admin")]
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IDockerOrchestratorService Orchestrator
@inject IContainerConfigService ConfigService
@inject NavigationManager Nav
@inject IConfiguration Config
@inject SetupDownloadService DownloadSvc
@using Microsoft.EntityFrameworkCore
@using FishAudioOrchestrator.Web.Data

<PageTitle>Deploy — Fish Audio Orchestrator</PageTitle>

<h2>Deploy Fish Speech Model</h2>

@if (!_modelPresent)
{
    <div class="alert alert-warning mb-3">
        <strong>No model found</strong> in the Checkpoints directory.
        @if (DownloadSvc.IsModelDownloading)
        {
            <div class="mt-2 bg-dark border border-secondary rounded p-2" style="height: 150px; overflow-y: auto; font-family: monospace; font-size: 0.8em;">
                @foreach (var line in DownloadSvc.GetModelDownloadOutput())
                {
                    <div>@line</div>
                }
            </div>
        }
        else if (DownloadSvc.ModelDownloadCompleted)
        {
            <div class="mt-2 alert alert-success mb-0">Model downloaded successfully. Refresh the page to continue.</div>
        }
        else
        {
            <p class="mb-2">Download the s2-pro model (~11 GB) to get started.</p>
            <button class="btn btn-success" @onclick="StartModelDownload">Download Model</button>
        }
    </div>
}

<div class="row">
    <div class="col-md-8 col-lg-6">
        <EditForm Model="_form" OnValidSubmit="HandleDeploy" FormName="deploy">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label">Model Name</label>
                <InputText class="form-control" @bind-Value="_form.Name" placeholder="e.g. narrator-v2" />
                <ValidationMessage For="() => _form.Name" />
            </div>

            <div class="mb-3">
                <label class="form-label">Checkpoint Path</label>
                <InputText class="form-control" @bind-Value="_form.CheckpointPath" />
                <small class="text-muted">Must contain model checkpoint files</small>
                <ValidationMessage For="() => _form.CheckpointPath" />
            </div>

            <div class="mb-3">
                <label class="form-label">Image Tag</label>
                <InputText class="form-control" @bind-Value="_form.ImageTag" />
            </div>

            <div class="mb-3">
                <label class="form-label">VRAM Config (optional)</label>
                <InputText class="form-control" @bind-Value="_form.CudaAllocConf"
                           placeholder="max_split_size_mb:512" />
                <small class="text-muted">Sets PYTORCH_CUDA_ALLOC_CONF</small>
            </div>

            <div class="mb-3 form-check">
                <InputCheckbox class="form-check-input" @bind-Value="_form.EnableHalf" />
                <label class="form-check-label">Enable FP16 (--half)</label>
                <small class="text-muted d-block">Recommended for ≤12GB VRAM</small>
            </div>

            @if (_activeModel is not null)
            {
                <div class="alert alert-warning">
                    Deploying will stop the currently active model
                    (<strong>@_activeModel.Name</strong>) before starting this one.
                </div>
            }

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger">@_error</div>
            }

            <button type="submit" class="btn btn-primary w-100" disabled="@_isDeploying">
                @if (_isDeploying)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <text>Deploying...</text>
                }
                else
                {
                    <text>Deploy Model</text>
                }
            </button>
        </EditForm>
    </div>
</div>

@implements IAsyncDisposable

@code {
    private DeployForm _form = new();
    private ModelProfile? _activeModel;
    private bool _isDeploying;
    private bool _modelPresent;
    private Timer? _deployDownloadTimer;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var dataRoot = Config["FishOrchestrator:DataRoot"] ?? @"C:\MyFishAudioProj";
        var defaultImage = Config["FishOrchestrator:DefaultImageTag"] ?? "fishaudio/fish-speech:server-cuda";

        _form.CheckpointPath = Path.Combine(dataRoot, "Checkpoints", "s2-pro");
        _form.ImageTag = defaultImage;

        await using (var db = await DbFactory.CreateDbContextAsync())
        {
            _activeModel = await db.ModelProfiles
                .FirstOrDefaultAsync(m => m.Status == ModelStatus.Running);
        }

        var checkpointsParent = Path.GetDirectoryName(_form.CheckpointPath.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar)) ?? _form.CheckpointPath;
        _modelPresent = DownloadSvc.IsModelPresent(checkpointsParent);
    }

    private async Task HandleDeploy()
    {
        _error = null;

        await using var db = await DbFactory.CreateDbContextAsync();

        // Validate name uniqueness
        if (await db.ModelProfiles.AnyAsync(m => m.Name == _form.Name))
        {
            _error = $"A model named '{_form.Name}' already exists.";
            return;
        }

        // Validate checkpoint path is within the Checkpoints directory
        var dataRoot = Config["FishOrchestrator:DataRoot"] ?? @"C:\MyFishAudioProj";
        var checkpointsRoot = Path.GetFullPath(Path.Combine(dataRoot, "Checkpoints"));
        var resolvedPath = Path.GetFullPath(_form.CheckpointPath!);
        if (!resolvedPath.StartsWith(checkpointsRoot + Path.DirectorySeparatorChar)
            && !resolvedPath.Equals(checkpointsRoot, StringComparison.OrdinalIgnoreCase))
        {
            _error = "Checkpoint path must be within the Checkpoints directory.";
            return;
        }

        // Validate checkpoint path exists
        if (!Directory.Exists(_form.CheckpointPath))
        {
            _error = $"Checkpoint path does not exist: {_form.CheckpointPath}";
            return;
        }

        _isDeploying = true;
        try
        {
            var port = await ConfigService.AllocatePortAsync();

            var profile = new ModelProfile
            {
                Name = _form.Name!.Trim(),
                CheckpointPath = _form.CheckpointPath!.Trim(),
                ImageTag = _form.ImageTag!.Trim(),
                HostPort = port,
                EnableHalf = _form.EnableHalf,
                CudaAllocConf = string.IsNullOrWhiteSpace(_form.CudaAllocConf)
                    ? null : _form.CudaAllocConf.Trim(),
                Status = ModelStatus.Created
            };

            db.ModelProfiles.Add(profile);
            await db.SaveChangesAsync();

            await Orchestrator.SwapModelAsync(profile);

            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            _error = $"Deployment failed: {ex.Message}";
        }
        finally
        {
            _isDeploying = false;
        }
    }

    private void StartModelDownload()
    {
        var checkpointsParent = Path.GetDirectoryName(_form.CheckpointPath?.TrimEnd(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar) ?? "") ?? _form.CheckpointPath ?? "";
        DownloadSvc.StartModelDownload(checkpointsParent, () => InvokeAsync(StateHasChanged));
        _deployDownloadTimer = new Timer(_ => InvokeAsync(() =>
        {
            if (!DownloadSvc.IsModelDownloading)
            {
                _deployDownloadTimer?.Dispose();
                _modelPresent = DownloadSvc.ModelDownloadCompleted;
            }
            StateHasChanged();
        }), null, 1000, 2000);
    }

    private class DeployForm
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Model name is required")]
        [System.ComponentModel.DataAnnotations.StringLength(100, MinimumLength = 1)]
        public string? Name { get; set; }

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Checkpoint path is required")]
        public string? CheckpointPath { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        public string? ImageTag { get; set; }

        public string? CudaAllocConf { get; set; }

        public bool EnableHalf { get; set; } = true;
    }

    public ValueTask DisposeAsync()
    {
        _deployDownloadTimer?.Dispose();
        return ValueTask.CompletedTask;
    }
}

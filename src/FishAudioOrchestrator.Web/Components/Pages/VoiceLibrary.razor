@page "/voices"
@attribute [Authorize]
@inject IVoiceLibraryService VoiceService
@using FishAudioOrchestrator.Web.Data

<PageTitle>Voice Library — Fish Audio Orchestrator</PageTitle>

<h2>Voice Library</h2>

<div class="row">
    <div class="col-lg-8">
        @if (_voices.Count == 0 && !_showAddForm)
        {
            <div class="alert alert-info">
                No reference voices yet. Add one to get started with voice cloning.
            </div>
        }
        else
        {
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Voice ID</th>
                        <th>Transcript</th>
                        <th>Tags</th>
                        <th>Preview</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var voice in _voices)
                    {
                        <tr>
                            <td>@voice.DisplayName</td>
                            <td><code>@voice.VoiceId</code></td>
                            <td><small class="text-muted">@Truncate(voice.TranscriptText, 50)</small></td>
                            <td><small>@voice.Tags</small></td>
                            <td>
                                <audio controls preload="none" style="height: 30px; max-width: 200px;">
                                    <source src="/audio/references/@voice.VoiceId/@voice.AudioFileName" />
                                </audio>
                            </td>
                            <td>
                                <AuthorizeView Roles="Admin">
                                    <Authorized>
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEdit(voice)">Edit</button>
                                        <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => RequestDelete(voice)">Delete</button>
                                    </Authorized>
                                </AuthorizeView>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <AuthorizeView Roles="Admin">
            <Authorized>
                <button class="btn btn-primary" @onclick="() => _showAddForm = !_showAddForm">
                    @(_showAddForm ? "Cancel" : "Add Voice")
                </button>
            </Authorized>
        </AuthorizeView>
    </div>

    <div class="col-lg-4">
        <AuthorizeView Roles="Admin">
            <Authorized>
                @if (_showAddForm)
                {
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Add Reference Voice</h5>

                            <div class="mb-3">
                                <label class="form-label">Display Name</label>
                                <input class="form-control" @bind="_addDisplayName" placeholder="e.g. Narrator" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Voice ID</label>
                                <input class="form-control" @bind="_addVoiceId" placeholder="e.g. narrator (alphanumeric, hyphens)" />
                                <small class="text-muted">Used as directory name and API reference ID</small>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Audio File (.wav)</label>
                                <InputFile class="form-control" OnChange="HandleFileUpload" accept=".wav" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Transcript Text</label>
                                <textarea class="form-control" @bind="_addTranscript" rows="3"
                                          placeholder="Exact text spoken in the audio file"></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Tags (optional)</label>
                                <input class="form-control" @bind="_addTags" placeholder="e.g. male,english,narrator" />
                            </div>

                            @if (!string.IsNullOrEmpty(_error))
                            {
                                <div class="alert alert-danger">@_error</div>
                            }

                            <button class="btn btn-success w-100" @onclick="AddVoice" disabled="@_isAdding">
                                @(_isAdding ? "Adding..." : "Add Voice")
                            </button>
                        </div>
                    </div>
                }

                @if (_editingVoice is not null)
                {
                    <div class="card mt-3">
                        <div class="card-body">
                            <h5 class="card-title">Edit: @_editingVoice.VoiceId</h5>

                            <div class="mb-3">
                                <label class="form-label">Display Name</label>
                                <input class="form-control" @bind="_editDisplayName" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Transcript</label>
                                <textarea class="form-control" @bind="_editTranscript" rows="3"></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Tags</label>
                                <input class="form-control" @bind="_editTags" />
                            </div>

                            <button class="btn btn-primary w-100" @onclick="SaveEdit">Save</button>
                            <button class="btn btn-secondary w-100 mt-1" @onclick="() => _editingVoice = null">Cancel</button>
                        </div>
                    </div>
                }
            </Authorized>
        </AuthorizeView>
    </div>
</div>

<ConfirmDialog @ref="_confirmDialog"
               Title="Delete Voice"
               Message="@_deleteMessage"
               ConfirmText="Delete"
               OnConfirm="_deleteAction" />

@code {
    private List<ReferenceVoice> _voices = new();
    private bool _showAddForm;
    private bool _isAdding;
    private string? _error;

    private string _addDisplayName = "";
    private string _addVoiceId = "";
    private string _addTranscript = "";
    private string _addTags = "";
    private IBrowserFile? _uploadedFile;

    private ReferenceVoice? _editingVoice;
    private string _editDisplayName = "";
    private string _editTranscript = "";
    private string _editTags = "";

    private ConfirmDialog _confirmDialog = null!;
    private string _deleteMessage = "";
    private EventCallback _deleteAction;

    protected override async Task OnInitializedAsync()
    {
        await LoadVoices();
    }

    private async Task LoadVoices()
    {
        _voices = await VoiceService.ListVoicesAsync();
    }

    private void HandleFileUpload(InputFileChangeEventArgs e)
    {
        _uploadedFile = e.File;
    }

    private async Task AddVoice()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_addDisplayName) || string.IsNullOrWhiteSpace(_addVoiceId)
            || string.IsNullOrWhiteSpace(_addTranscript) || _uploadedFile is null)
        {
            _error = "All fields are required (name, voice ID, audio file, transcript).";
            return;
        }

        if (!System.Text.RegularExpressions.Regex.IsMatch(_addVoiceId.Trim(), @"^[a-zA-Z0-9_-]+$"))
        {
            _error = "Voice ID must contain only letters, numbers, hyphens, and underscores.";
            return;
        }

        _isAdding = true;
        try
        {
            using var stream = _uploadedFile.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            await VoiceService.AddVoiceAsync(_addDisplayName.Trim(), _addVoiceId.Trim(),
                stream, _addTranscript.Trim(),
                string.IsNullOrWhiteSpace(_addTags) ? null : _addTags.Trim());

            _addDisplayName = "";
            _addVoiceId = "";
            _addTranscript = "";
            _addTags = "";
            _uploadedFile = null;
            _showAddForm = false;
            await LoadVoices();
        }
        catch (Exception ex)
        {
            _error = $"Failed to add voice: {ex.Message}";
        }
        finally
        {
            _isAdding = false;
        }
    }

    private void StartEdit(ReferenceVoice voice)
    {
        _editingVoice = voice;
        _editDisplayName = voice.DisplayName;
        _editTranscript = voice.TranscriptText;
        _editTags = voice.Tags ?? "";
    }

    private async Task SaveEdit()
    {
        if (_editingVoice is null) return;

        await VoiceService.UpdateVoiceAsync(_editingVoice.Id,
            _editDisplayName.Trim(), _editTranscript.Trim(),
            string.IsNullOrWhiteSpace(_editTags) ? null : _editTags.Trim());

        _editingVoice = null;
        await LoadVoices();
    }

    private void RequestDelete(ReferenceVoice voice)
    {
        _deleteMessage = $"Delete voice '{voice.DisplayName}' ({voice.VoiceId})? This removes the audio files.";
        _deleteAction = EventCallback.Factory.Create(this, async () =>
        {
            await VoiceService.DeleteVoiceAsync(voice.Id);
            await LoadVoices();
        });
        _confirmDialog.Show();
    }

}
